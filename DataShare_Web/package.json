{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "start:coverage": "npm run build:coverage && npm run instrument:coverage && node scripts/serve-cypress-coverage.cjs",
    "build:coverage": "ng build --configuration development --output-hashing=none",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "jest": "npm run test -- --coverage",
    "e2e": "cypress run",
    "e2e:coverage": "cypress run --config baseUrl=http://localhost:4201",
    "instrument:coverage": "node scripts/instrument-dist-for-cypress.cjs",
    "coverage:clean": "node scripts/clean-coverage-artifacts.cjs",
    "coverage:report": "nyc report --temp-dir .nyc_output --report-dir coverage/combined --reporter=html --reporter=text-summary",
    "cy:coverage": "start-server-and-test start:coverage http://localhost:4201 \"cypress run --config baseUrl=http://localhost:4201\"",
    "perf:smoke": "node scripts/run-k6.cjs smoke",
    "perf:load": "node scripts/run-k6.cjs load",
    "perf:k6": "node scripts/run-k6.cjs"
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@cypress/code-coverage": "^4.0.3",
    "@types/jest": "^30.0.0",
    "cypress": "^15.13.1",
    "http-server": "^14.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.2",
    "jsdom": "^28.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.2",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
